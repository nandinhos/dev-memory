# Imagem de DESENVOLVIMENTO — não é a de produção (Dockerfile).
#
# Diferenças deliberadas:
#  - PHP 8.4: o composer.json exige ^8.4. A imagem de produção ainda está em 8.3
#    (divergência anotada para corrigir lá; aqui seguimos o que o código pede).
#  - Sem COPY do código nem build de assets: o código entra por bind-mount, então
#    editar um arquivo reflete na hora, sem rebuild.
#  - Com Xdebug disponível (desligado por padrão — ligue com XDEBUG_MODE).
FROM php:8.4-cli

ARG UID=1000
ARG GID=1000

RUN apt-get update && apt-get install -y --no-install-recommends \
        git unzip libzip-dev zlib1g-dev libpq-dev libicu-dev libpng-dev libjpeg-dev libfreetype6-dev \
        postgresql-client \
    && rm -rf /var/lib/apt/lists/*

RUN docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j"$(nproc)" pdo pdo_pgsql pgsql zip intl bcmath gd exif pcntl

# pecl em passo próprio: quando falha (ex.: unpack sem zlib) o erro fica isolado
# aqui em vez de derrubar a camada inteira de extensões.
RUN pecl install redis xdebug \
    && docker-php-ext-enable redis

# Xdebug fica INSTALADO mas inerte: sem XDEBUG_MODE a execução não paga o custo.
RUN echo "zend_extension=xdebug\nxdebug.mode=\${XDEBUG_MODE}\nxdebug.client_host=host.docker.internal\nxdebug.start_with_request=trigger" \
        > /usr/local/etc/php/conf.d/99-xdebug.ini

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Usuário com o MESMO uid/gid do host: sem isso todo arquivo criado pelo container
# (cache, log, storage) nasce root-owned e trava o artisan rodado fora dele.
RUN groupadd -g ${GID} app 2>/dev/null || true \
    && useradd -u ${UID} -g ${GID} -m -s /bin/bash app 2>/dev/null || true

WORKDIR /var/www/html
USER app

EXPOSE 8000
CMD ["php", "artisan", "serve", "--host=0.0.0.0", "--port=8000"]
